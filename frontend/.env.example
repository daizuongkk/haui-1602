# URL backend đã deploy trên Render. Next.js rewrites sẽ proxy /api và /audio về đây.
# Trên Vercel: Project Settings → Environment Variables → thêm BACKEND_URL.
BACKEND_URL=https://dienbien-weather-api.onrender.com

