# Backend — biến môi trường (Render đặt trong Blueprint/Environment; local đặt trong .env này).
# Có key → dịch bản tin sang Thái/H'Mông. Không có → pipeline vẫn chạy, chỉ tiếng Việt.
GEMINI_API_KEY=

