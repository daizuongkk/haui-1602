{
  "openapi": "3.1.0",
  "info": {
    "title": "Điện Biên Weather Alert API",
    "description": "\nAPI của **Hệ thống AI Cảnh báo & Dự báo Thời tiết Vi mô — Điện Biên**.\n\nCung cấp dữ liệu dự báo/cảnh báo thiên tai cấp huyện, bản tin đa ngôn ngữ (Việt · Thái · H'Mông),\nvà mô phỏng phân phối đa kênh cho giao diện người dân + dashboard chỉ huy.\n\n### Khái niệm chính\n- **Mức cảnh báo (4 cấp):** `Green` (Bình thường) · `Yellow` (Chú ý) · `Orange` (Nguy hiểm) · `Red` (Cực kỳ nguy hiểm).\n- **Khoá dữ liệu:** mỗi bản ghi định danh bằng `(location_id, date)` với `date` dạng `dd/mm/yyyy`.\n- **Audio:** các URL `/audio/...` trỏ tới file mp3 tĩnh (giọng đọc bản tin theo ngôn ngữ).\n\n### Ghi chú\n- API **chỉ đọc**; endpoint phân phối **chỉ mô phỏng**, không gửi SMS/Zalo/loa thật.\n- Tài liệu tương tác: **Swagger UI** tại `/docs`, **ReDoc** tại `/redoc`, đặc tả JSON tại `/openapi.json`.\n",
    "contact": {
      "name": "Đội dự thi — Vietnam AI Innovation Challenge"
    },
    "license": {
      "name": "MIT"
    },
    "version": "1.0.0"
  },
  "paths": {
    "/api/locations": {
      "get": {
        "tags": [
          "Địa điểm"
        ],
        "summary": "Danh sách huyện được giám sát",
        "description": "Trả về 3 huyện demo (Mường Nhé, Mường Chà, Tuần Giáo) kèm toạ độ, độ cao và hệ số rủi ro sạt lở.",
        "operationId": "get_locations_api_locations_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/LocationOut"
                  },
                  "type": "array",
                  "title": "Response Get Locations Api Locations Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/summary": {
      "get": {
        "tags": [
          "Cảnh báo"
        ],
        "summary": "Tổng quan mức cảnh báo theo huyện",
        "description": "Mức cảnh báo cao nhất hiện tại của **từng huyện** (dùng để tô màu bản đồ) và **số huyện theo từng mức** (KPI cho dashboard). Ưu tiên mức: Red > Orange > Yellow > Green.",
        "operationId": "get_summary_api_summary_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SummaryResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/alerts/active": {
      "get": {
        "tags": [
          "Cảnh báo"
        ],
        "summary": "Các ngày đang có cảnh báo",
        "description": "Tất cả bản ghi cảnh báo đang hiệu lực (mức ≥ Vàng), đã hợp nhất số liệu thời tiết, danh sách hiểm họa, bản tin đa ngôn ngữ và URL audio.",
        "operationId": "get_active_alerts_api_alerts_active_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/AlertRecord"
                  },
                  "type": "array",
                  "title": "Response Get Active Alerts Api Alerts Active Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/forecast/{location_id}": {
      "get": {
        "tags": [
          "Dự báo"
        ],
        "summary": "Dự báo 3–7 ngày của một huyện",
        "description": "Chuỗi dự báo theo ngày (đã sắp xếp tăng dần) cho một huyện, mỗi ngày là một bản ghi đã làm giàu.",
        "operationId": "get_forecast_api_forecast__location_id__get",
        "parameters": [
          {
            "name": "location_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Mã huyện",
              "examples": [
                "muong_nhe"
              ],
              "title": "Location Id"
            },
            "description": "Mã huyện",
            "examples": {
              "muong_nhe": {
                "summary": "Huyện Mường Nhé",
                "value": "muong_nhe"
              },
              "muong_cha": {
                "summary": "Huyện Mường Chà",
                "value": "muong_cha"
              },
              "tuan_giao": {
                "summary": "Huyện Tuần Giáo",
                "value": "tuan_giao"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AlertRecord"
                  },
                  "title": "Response Get Forecast Api Forecast  Location Id  Get"
                }
              }
            }
          },
          "404": {
            "description": "Không tìm thấy tài nguyên",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/alerts/broadcast": {
      "post": {
        "tags": [
          "Phân phối"
        ],
        "summary": "Mô phỏng phân phối cảnh báo đa kênh",
        "description": "Dựng sẵn nội dung sẽ gửi qua **SMS / Zalo OA / loa phát thanh** cho một cảnh báo, để minh hoạ lớp phân phối. ⚠️ **Chỉ mô phỏng — hệ thống không gửi tin thật.**",
        "operationId": "broadcast_alert_api_alerts_broadcast_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BroadcastRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BroadcastResponse"
                }
              }
            }
          },
          "404": {
            "description": "Không tìm thấy tài nguyên",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/health": {
      "get": {
        "tags": [
          "Hệ thống"
        ],
        "summary": "Kiểm tra tình trạng dịch vụ",
        "description": "Trạng thái dịch vụ và số bản ghi cảnh báo hiện có.",
        "operationId": "health_api_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    }
  },
